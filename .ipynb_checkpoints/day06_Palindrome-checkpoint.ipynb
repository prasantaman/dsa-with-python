   "source": [
    "def ispalindrome(n): \n",
    "    if n<0:\n",
    "        return False\n",
    "    original = n \n",
    "    reverse = 0\n",
    "    while n>0:\n",
    "        digit = n%10\n",
    "        reverse = reverse *10+digit\n",
    "        n = n//10\n",
    "    return original == reverse     "
   ]
  },
